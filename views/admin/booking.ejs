<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Manage Booking | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>
        <div class="card mb-4">
    <div class="card-header"><i class="fas fa-table me-1"></i> Data Booking Puskesmas</div>
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nama Pasien</th>
                    <th>Puskesmas Tujuan</th>
                    <th>Jadwal (Tanggal/Jam)</th>
                    <th>Keluhan</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% dataBooking.forEach(book => { %>
                    <tr>
                        <td><%= book.nama_user %></td>
                        <td><%= book.puskesmas %></td>
                        <td><span class="badge bg-primary"><%= book.tanggal %></span> <%= book.jam %></td>
                        <td><%= book.keluhan %></td>
                        <td>
                            <a href="/admin/booking/hapus/<%= book.id %>" class="btn btn-sm btn-success">
                                Tandai Selesai
                            </a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
    </div>
</body>
</html>