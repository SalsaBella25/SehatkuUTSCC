<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kelola Booking | HealthBridge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>
        
        <div class="p-5" style="margin-left: 250px; width: 100%;">
            <h2 class="fw-bold mb-4 text-dark">Data Booking Puskesmas</h2>
            
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0 overflow-hidden">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th class="px-4 py-3">Pasien</th>
                                <th class="py-3">Puskesmas</th>
                                <th class="py-3">Jadwal</th>
                                <th class="py-3">Keluhan</th>
                                <th class="py-3 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% dataBooking.forEach(b => { %>
                            <tr>
                                <td class="px-4 fw-bold"><%= b.nama_user %></td>
                                <td><span class="badge bg-info text-dark"><%= b.puskesmas %></span></td>
                                <td><%= b.tanggal %> <br> <small class="text-muted"><%= b.jam %></small></td>
                                <td style="max-width: 200px;" class="text-truncate"><%= b.keluhan %></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-success rounded-pill px-3">Selesai</button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>