<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kelola Penyakit | HealthBridge Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>

        <div class="content p-5" style="margin-left: 250px; width: 100%;">
            <h2 class="fw-bold mb-4">Kelola Data Penyakit</h2>

            <div class="card border-0 shadow-sm rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-activity me-2 text-success"></i>Visualisasi Tren Penyakit</h5>
                <canvas id="adminDiseaseChart" style="max-height: 300px;"></canvas>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                </div>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('adminDiseaseChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar', // Bisa ganti 'line' kalau mau garis
            data: {
                labels: <%- JSON.stringify(dataPenyakit.map(d => d.nama)) %>,
                datasets: [{
                    label: 'Jumlah Kasus',
                    data: <%- JSON.stringify(dataPenyakit.map(d => d.kasus)) %>,
                    backgroundColor: 'rgba(25, 135, 84, 0.2)',
                    borderColor: '#198754',
                    borderWidth: 2,
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
</body>
</html>