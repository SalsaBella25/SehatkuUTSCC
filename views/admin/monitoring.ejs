<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kelola Penyakit | HealthBridge Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>

        <div class="content p-5" style="margin-left: 280px; width: 100%;">
            <h2 class="fw-bold mb-4">Kelola Data Penyakit</h2>

            <div class="card border-0 shadow-sm rounded-4 mb-4 p-4">
                <h5 class="fw-bold mb-3"><i class="bi bi-activity me-2 text-success"></i>Visualisasi Tren Penyakit</h5>
                <canvas id="adminDiseaseChart" style="max-height: 300px;"></canvas>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Input Data Penyakit Baru</h5>
                </div>
                <div class="card-body p-4">
                    <form action="/admin/tambah" method="POST" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Nama Penyakit</label>
                            <input type="text" name="nama" class="form-control bg-light" placeholder="Misal: DHF" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Wilayah</label>
                            <input type="text" name="wilayah" class="form-control bg-light" placeholder="Misal: Bandung" required>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">Kasus</label>
                            <input type="number" name="kasus" class="form-control bg-light" placeholder="0" required>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">Tanggal</label>
                            <input type="date" name="tanggal" class="form-control bg-light" required>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100 shadow-sm">Simpan Data</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="px-4 py-3">Penyakit</th>
                            <th>Wilayah</th>
                            <th>Kasus</th>
                            <th>Tanggal</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dataPenyakit.forEach(p => { %>
                        <tr>
                            <td class="px-4 fw-bold text-dark"><%= p.nama %></td>
                            <td class="text-secondary"><%= p.wilayah %></td>
                            <td><span class="badge bg-danger rounded-pill px-3 py-2"><%= p.kasus %> Kasus</span></td>
                            <td class="text-secondary"><%= new Date(p.tanggal).toLocaleDateString('id-ID') %></td>
                            <td class="text-center">
                                <a href="/admin/monitoring/hapus/<%= p.id %>" class="btn btn-outline-danger btn-sm rounded-3 px-3" onclick="return confirm('Hapus data ini?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        const ctx = document.getElementById('adminDiseaseChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: <%- JSON.stringify(dataPenyakit.map(d => d.nama)) %>,
                datasets: [{
                    label: 'Jumlah Kasus',
                    data: <%- JSON.stringify(dataPenyakit.map(d => d.kasus)) %>,
                    backgroundColor: 'rgba(25, 135, 84, 0.2)',
                    borderColor: '#198754',
                    borderWidth: 2,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                scales: { y: { beginAtZero: true } }
            }
        });
    </script>
</body>
</html>