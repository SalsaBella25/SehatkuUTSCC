<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kelola Penyakit | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>

        <div class="content p-5" style="margin-left: 250px; width: 100%;">
            <h2 class="fw-bold mb-4"><i class="bi bi-graph-up-arrow me-2"></i>Kelola Data Penyakit</h2>
            
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Input Data Penyakit Baru</h5>
                </div>
                <div class="card-body p-4">
                    <form action="/admin/tambah" method="POST" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Nama Penyakit</label>
                            <input type="text" name="nama" class="form-control" placeholder="Misal: DHF" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Wilayah/Kota</label>
                            <input type="text" name="wilayah" class="form-control" placeholder="Misal: Bandung" required>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Kasus</label>
                            <input type="number" name="kasus" class="form-control" placeholder="0" required>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Tanggal</label>
                            <input type="date" name="tanggal" class="form-control" required>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">Simpan Data</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th class="px-4 py-3">Penyakit</th>
                            <th>Wilayah</th>
                            <th>Kasus</th>
                            <th>Tanggal</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dataPenyakit.forEach(p => { %>
                        <tr>
                            <td class="px-4 fw-bold"><%= p.nama %></td>
                            <td><%= p.wilayah %></td>
                            <td><span class="badge bg-danger rounded-pill"><%= p.kasus %> Kasus</span></td>
                            <td><%= new Date(p.tanggal).toLocaleDateString('id-ID') %></td>
                            <td class="text-center">
                                <a href="/admin/monitoring/hapus/<%= p.id %>" class="btn btn-outline-danger btn-sm" onclick="return confirm('Hapus?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>