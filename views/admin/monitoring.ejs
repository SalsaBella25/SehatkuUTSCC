<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Manage Monitoring | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>
        <div class="content p-5" style="margin-left: 280px; width: 100%;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">Kelola Data Penyakit</h2>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalTambah">
                    <i class="bi bi-plus-lg"></i> Tambah Data
                </button>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="px-4">Penyakit</th>
                            <th>Wilayah</th>
                            <th>Kasus</th>
                            <th>Tanggal</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dataPenyakit.forEach(p => { %>
                        <tr>
                            <td class="px-4 fw-bold"><%= p.nama %></td>
                            <td><%= p.wilayah %></td>
                            <td><span class="badge bg-danger"><%= p.kasus %> Kasus</span></td>
                            <td><%= p.tanggal %></td>
                            <td>
                                <a href="/admin/monitoring/hapus/<%= p.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Hapus data?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalTambah" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/admin/tambah" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">Input Kasus Baru</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nama Penyakit</label>
                            <input type="text" name="nama" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Wilayah</label>
                            <input type="text" name="wilayah" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Jumlah Kasus</label>
                            <input type="number" name="kasus" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tanggal</label>
                            <input type="date" name="tanggal" class="form-control" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>