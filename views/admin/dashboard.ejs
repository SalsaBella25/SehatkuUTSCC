<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | SehaTku</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <%- include('../partials/navbar') %>

    <div class="container py-5">
        <div class="row mb-4">
            <div class="col">
                <h2 class="fw-bold"><i class="bi bi-speedometer2"></i> Panel Admin CRUD</h2>
                <p class="text-muted">Kelola data pemantauan kesehatan wilayah.</p>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-3 mb-5">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="card-title mb-0"><i class="bi bi-plus-circle"></i> Input Data Penyakit Baru</h5>
            </div>
            <div class="card-body p-4">
                <form action="/admin/tambah" method="POST" class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Nama Penyakit</label>
                        <input type="text" name="nama" class="form-control" placeholder="Misal: DHF, Flu Burung" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Wilayah/Kota</label>
                        <input type="text" name="wilayah" class="form-control" placeholder="Misal: Bandung" required>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Jumlah Kasus</label>
                        <input type="number" name="kasus" class="form-control" placeholder="0" required>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tanggal Laporan</label>
                        <input type="date" name="tanggal" class="form-control" required>
                    </div>
                    <div class="col-12 mt-4 text-end">
                        <button type="submit" class="btn btn-primary px-4 shadow">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="px-4">Penyakit</th>
                                <th>Wilayah</th>
                                <th>Kasus</th>
                                <th>Tanggal</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% dataPenyakit.forEach(p => { %>
                            <tr>
                                <td class="px-4 fw-bold"><%= p.nama %></td>
                                <td><%= p.wilayah %></td>
                                <td><span class="badge bg-danger rounded-pill"><%= p.kasus %> Kasus</span></td>
                                <td><%= p.tanggal %></td>
                                <td class="text-center">
                                    <a href="/admin/hapus/<%= p.id %>" class="btn btn-outline-danger btn-sm" onclick="return confirm('Yakin hapus data ini?')">
                                        <i class="bi bi-trash"></i> Hapus
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/admin">
            <i class="bi bi-speedometer2 me-2"></i>HealthBridge Admin
        </a>

        <div class="ms-auto d-flex gap-2">
            <a href="/" class="btn btn-light text-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-house-door-fill me-2"></i>Kembali ke Web
            </a>
            
            <div class="dropdown">
                <button class="btn btn-outline-light dropdown-toggle rounded-pill px-4" type="button" data-bs-toggle="dropdown">
                    Menu Fitur
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                    <li><a class="dropdown-item py-2" href="/admin/booking"><i class="bi bi-calendar-check me-2 text-success"></i>Kelola Booking</a></li>
                    <li><a class="dropdown-item py-2" href="/admin/laporan"><i class="bi bi-file-earmark-medical me-2 text-warning"></i>Kelola Laporan</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item py-2 text-danger" href="/"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<div class="container pb-5">
    <div class="row mb-3">
        <div class="col">
            <h2 class="fw-bold"><i class="bi bi-speedometer2"></i> Panel Admin CRUD</h2>
            <p class="text-muted">Kelola data pemantauan kesehatan wilayah secara real-time.</p>
        </div>
    </div>
    
    </div>
</html>