<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | HealthBridge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/admin">
                <i class="bi bi-shield-lock-fill me-2"></i>HealthBridge Admin
            </a>
            
            <div class="collapse navbar-collapse" id="adminNav">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item">
                        <a class="btn btn-light text-primary rounded-pill px-4 fw-bold shadow-sm" href="/admin/monitoring">
                            <i class="bi bi-graph-up me-2"></i>Kelola Penyakit
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light rounded-pill px-4" href="/admin/booking">
                            Kelola Booking
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light rounded-pill px-4" href="/admin/laporan">
                            Kelola Laporan
                        </a>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <a href="/" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm text-dark">
                            <i class="bi bi-house-door me-1"></i>Kembali ke Web
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="row mb-4">
            <div class="col">
                <h2 class="fw-bold text-dark">Panel Admin Utama</h2>
                <p class="text-muted">Gunakan menu di atas untuk mengelola data kesehatan, booking, dan laporan masyarakat.</p>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 rounded-4 bg-white">
                    <h6 class="text-muted">Total Data Penyakit</h6>
                    <h2 class="fw-bold mb-0 text-primary"><%= dataPenyakit.length %></h2>
                </div>
            </div>
            </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-0">
                <h5 class="mb-0 fw-bold">Ringkasan Riwayat Penyakit</h5>
            </div>
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="px-4 py-3">Penyakit</th>
                        <th>Wilayah</th>
                        <th>Kasus</th>
                        <th>Tanggal</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% dataPenyakit.forEach(p => { %>
                    <tr>
                        <td class="px-4 fw-bold"><%= p.nama %></td>
                        <td><%= p.wilayah %></td>
                        <td><span class="badge bg-danger rounded-pill px-3"><%= p.kasus %> Kasus</span></td>
                        <td><%= new Date(p.tanggal).toLocaleDateString('id-ID') %></td>
                        <td class="text-center">
                            <a href="/admin/monitoring/hapus/<%= p.id %>" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>