<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Manage Laporan | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>
        <div class="content p-5" style="margin-left: 280px; width: 100%;">
            <h2 class="fw-bold mb-4">Daftar Laporan Warga (AWS S3)</h2>
            <div class="row g-4">
                <% dataLaporan.forEach(l => { %>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden">
                        <img src="<%= l.foto_url %>" class="card-img-top" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="fw-bold"><%= l.judul %></h5>
                            <p class="small text-muted mb-1"><i class="bi bi-geo-alt"></i> <%= l.lokasi %></p>
                            <p class="card-text text-truncate"><%= l.deskripsi %></p>
                            <a href="/admin/laporan/hapus/<%= l.id %>" class="btn btn-danger btn-sm w-100" onclick="return confirm('Hapus laporan?')">Hapus</a>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
</body>
</html>