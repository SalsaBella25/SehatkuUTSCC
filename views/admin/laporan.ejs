<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kelola Laporan | HealthBridge Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>

        <div class="content p-5" style="margin-left: 250px; width: 100%;">
            <div class="mb-4">
                <h2 class="fw-bold text-dark">Daftar Laporan Lingkungan Masyarakat</h2>
                <p class="text-muted">Foto laporan tersimpan secara aman di AWS S3.</p>
            </div>

            <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
                <% dataLaporan.forEach(l => { %>
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">
                        <span class="position-absolute top-0 start-0 m-2 badge bg-dark bg-opacity-75 rounded-pill px-3">
                            <i class="bi bi-person me-1"></i> <%= l.nama %>
                        </span>

                        <div style="height: 200px; width: 100%;">
                            <img src="<%= l.foto %>" class="card-img-top h-100 w-100" style="object-fit: cover;" alt="Foto Laporan">
                        </div>

                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-2">Isi Laporan:</h6>
                            <p class="card-text small text-secondary mb-3" style="min-height: 40px;">
                                "<%= l.keluhan %>"
                            </p>
                            
                            <div class="pt-2 border-top">
                                <a href="/admin/laporan/hapus/<%= l.id %>" 
                                   class="btn btn-outline-danger btn-sm w-100 rounded-pill" 
                                   onclick="return confirm('Hapus laporan ini dari database?')">
                                    <i class="bi bi-trash3 me-1"></i> Hapus Laporan
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

            <% if (dataLaporan.length === 0) { %>
                <div class="text-center py-5 mt-5">
                    <div class="display-1 text-muted opacity-25"><i class="bi bi-images"></i></div>
                    <h5 class="text-muted mt-3">Belum ada foto laporan yang diunggah.</h5>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>