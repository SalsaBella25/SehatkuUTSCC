<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Manage Laporan | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="d-flex">
        <%- include('../partials/sidebar') %>
        <div class="row">
    <% dataLaporan.forEach(item => { %>
        <div class="col-md-4">
            <div class="card mb-4">
                <img src="<%= item.foto %>" class="card-img-top" style="height: 200px; object-fit: cover;" 
                     onerror="this.src='https://via.placeholder.com/300x200?text=S3+Error'">
                
                <div class="card-body">
                    <h5 class="card-title"><%= item.nama %></h5>
                    <p><%= item.keluhan %></p>
                    <a href="/admin/laporan/hapus/<%= item.id %>" 
                       class="btn btn-danger w-100" 
                       onclick="return confirm('Hapus laporan ini?')">Hapus</a>
                </div>
            </div>
        </div>
    <% }) %>
</div>
    </div>
</body>
</html>