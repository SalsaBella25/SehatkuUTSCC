<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Manage Laporan | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="p-5" style="margin-left: 250px; width: 100%;">
    <h2 class="fw-bold mb-4 text-dark">Kelola Laporan Lingkungan</h2>
    
    <div class="row row-cols-1 row-cols-md-4 g-3">
        <% dataLaporan.forEach(l => { %>
        <div class="col">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <img src="<%= l.foto %>" class="card-img-top" style="height: 140px; object-fit: cover;">
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1 text-primary"><%= l.nama %></h6>
                    <p class="small text-muted mb-3" style="font-size: 0.8rem;"><%= l.keluhan %></p>
                    <a href="/admin/laporan/hapus/<%= l.id %>" class="btn btn-outline-danger btn-sm w-100 rounded-pill" onclick="return confirm('Hapus laporan?')">
                        <i class="bi bi-trash me-1"></i> Hapus
                    </a>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>
</body>
</html>