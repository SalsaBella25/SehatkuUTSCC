<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Kirim Laporan | HealthBridge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5">
                        <a href="/" class="btn btn-link text-decoration-none mb-3"><i class="bi bi-arrow-left"></i> Kembali ke Beranda</a>
                        <h2 class="fw-bold mb-4">Form Laporan Kesehatan Lingkungan</h2>
                        
                        <form action="/lapor" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Nama Pelapor</label>
                                <input type="text" name="nama" class="form-control form-control-lg" placeholder="Masukkan nama lengkap" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Jenis Masalah Kesehatan</label>
                                <select name="kategori" class="form-select form-select-lg">
                                    <option value="Sanitasi">Sanitasi/Sampah</option>
                                    <option value="Wabah">Potensi Wabah Penyakit</option>
                                    <option value="Fasilitas">Fasilitas Kesehatan Rusak</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Deskripsi Laporan</label>
                                <textarea name="deskripsi" class="form-control" rows="4" placeholder="Jelaskan detail kondisi di lapangan..." required></textarea>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">Unggah Bukti Foto (Wajib S3)</label>
                                <input type="file" name="foto" class="form-control" accept="image/*" required>
                                <div class="form-text text-danger">*Foto akan disimpan secara otomatis di AWS S3.</div>
                            </div>
                            <button type="submit" class="btn btn-primary-custom w-100 py-3 shadow">Kirim Laporan ke Pemerintah</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>